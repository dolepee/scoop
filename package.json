{
  "name": "scoop-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scoop: self-custody BSC trading agent that pays for its own intelligence via x402 and writes verifiable receipts. BNB Hack: AI Trading Agent Edition.",
  "scripts": {
    "cycle": "node src/cycle.mjs",
    "cycle:dry": "node src/cycle.mjs",
    "test": "node --test",
    "receipts:verify": "node src/verify-receipts.mjs",
    "cycle:paid": "SCOOP_PAID=1 node src/cycle.mjs",
    "cycle:live": "SCOOP_PAID=1 SCOOP_TRADE=1 node src/cycle.mjs"
  },
  "dependencies": {
    "@trustwallet/cli": "^0.17.0"
  }
}
